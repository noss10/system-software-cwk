    public boolean validateUser(String user, String pass) throws InvalidKeySpecException, ClassNotFoundException {
    Boolean flag = false;
    try {
        connection = getConnection();
        var statement = connection.createStatement();
        statement.setQueryTimeout(timeout);
        ResultSet rs = statement.executeQuery("select name, password from " + this.dataBaseTableName);
        
        String inPass = generateSecurePassword(pass);
        
        System.out.println("--- DEBUGGING LOGIN ---");
        System.out.println("Trying to log in as: " + user);
        
        while (rs.next()) {
            String dbName = rs.getString("name");
            String dbPass = rs.getString("password");

            if (user.equals(dbName)) {
                System.out.println("FOUND USER '" + user + "' in database!");
                System.out.println("Database Password: " + dbPass);
                System.out.println("Your Typed Hash:   " + inPass);
                
                if (dbPass.equals(inPass)) {
                    System.out.println("SUCCESS: Passwords match!");
                    flag = true;
                    break;
                } else {
                    System.out.println("FAILURE: Passwords do not match.");
                    if (pass.equals(dbPass)) {
                        System.out.println("WARNING: The database password is NOT encrypted (Plain Text). You cannot log in with this user via Java.");
                    }
                }
            }
        }
    } catch (SQLException ex) {
        Logger.getLogger(DB.class.getName()).log(Level.SEVERE, null, ex);
    } finally {
        try {
            if (connection != null) {
                connection.close();
            }
        } catch (SQLException e) {
            System.err.println(e.getMessage());
        }
    }
    return flag;
}
  
    public User authenticate(String user, String pass) throws InvalidKeySpecException, ClassNotFoundException {
        try {
