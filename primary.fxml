   public void saveEncryptedFile(String owner, String name, String plainText) throws Exception {
        KeyGenerator keyGen = KeyGenerator.getInstance("AES");
        keyGen.init(256);
        SecretKey secretKey = keyGen.generateKey();
        String encodedKey = Base64.getEncoder().encodeToString(secretKey.getEncoded());
        Cipher cipher = Cipher.getInstance("AES");
        cipher.init(Cipher.ENCRYPT_MODE, secretKey);
        byte[] encryptedBytes = cipher.doFinal(plainText.getBytes());
        String encryptedContent = Base64.getEncoder().encodeToString(encryptedBytes);
        String sql = "INSERT INTO Files (owner, filename, content, encryption_key) VALUES (?, ?, ?, ?)";
        try {
            // UPDATED TO MYSQL
            connection = getConnection();
            java.sql.PreparedStatement pstmt = connection.prepareStatement(sql);
            pstmt.setString(1, owner);
            pstmt.setString(2, name);
            pstmt.setString(3, encryptedContent);
            pstmt.setString(4, encodedKey);
            pstmt.executeUpdate();

            syncData(sql, owner, name, encryptedContent, encodedKey);

        } finally {
            try {
                if (connection != null) connection.close();
            } catch (SQLException e) {
                System.err.println(e.getMessage());
            }
        }
    }

    public ObservableList<UserFiles> getUserFiles(String owner) {
        ObservableList<UserFiles> files = FXCollections.observableArrayList();
        String sql = "SELECT DISTINCT f.id, f.filename, f.content, f.encryption_key " +
                     "FROM Files f " +
                     "LEFT JOIN Permissions p ON f.id = p.file_id " +
                     "WHERE f.owner = ? OR p.shared_with = ?";
        
        try {
            // UPDATED TO MYSQL
            connection = getConnection();
            java.sql.PreparedStatement pstmt = connection.prepareStatement(sql);
            pstmt.setString(1, owner);
            pstmt.setString(2, owner);
            ResultSet rs = pstmt.executeQuery();
            
            while (rs.next()) {
                files.add(new UserFiles(
                    rs.getInt("id"),
                    rs.getString("filename"),
                    rs.getString("content"),
                    rs.getString("encryption_key")
                ));
            }
        } catch (Exception ex) {
            ex.printStackTrace();
        } finally {
            try { if (connection != null) connection.close(); } catch (SQLException e) {}
        }
        return files;
    }
    

    public String decryptFile(String encryptedContent, String keyStr) throws Exception {
        byte[] decodedKey = Base64.getDecoder().decode(keyStr);
        SecretKey secretKey = new SecretKeySpec(decodedKey, 0, decodedKey.length, "AES");

        Cipher cipher = Cipher.getInstance("AES");
        cipher.init(Cipher.DECRYPT_MODE, secretKey);
        
        byte[] decodedContent = Base64.getDecoder().decode(encryptedContent);
        byte[] decryptedBytes = cipher.doFinal(decodedContent);
        
        return new String(decryptedBytes);
    }
