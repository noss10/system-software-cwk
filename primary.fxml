  public void syncData(String sql, String... params) {
        log("DATABASE SYNC: Mirroring to Remote Backup File...");
        try (java.io.FileWriter fw = new java.io.FileWriter("remote_sync_log.txt", true)) {
            String timestamp = new java.util.Date().toString();
            fw.write("[" + timestamp + "] SYNC QUERY: " + sql + "\n");
            fw.write("[" + timestamp + "] DATA: " + java.util.Arrays.toString(params) + "\n\n");
            log("SYNC SUCCESS: Local and Remote states are now consistent.");
        } catch (java.io.IOException e) {
            log("SYNC ERROR: Backup file unreachable.");
        }
    }

    public String executeTerminalCommand(String command) {
        StringBuilder output = new StringBuilder();
        try {
            Process process = Runtime.getRuntime().exec(new String[]{"/bin/sh", "-c", command});
            java.io.BufferedReader reader = new java.io.BufferedReader(new java.io.InputStreamReader(process.getInputStream()));
            String line;
            while ((line = reader.readLine()) != null) {
                output.append(line).append("\n");
            }
            process.waitFor();
        } catch (Exception e) {
            return "Error: " + e.getMessage();
        }
        return output.toString().isEmpty() ? "Command executed." : output.toString();
    }
